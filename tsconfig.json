{
  "compilerOptions": {
    "module": "commonjs",
    "target": "es2019",
    "rootDir": "./src",
    "outDir": "./dist",

    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,

    "esModuleInterop": true,
    "strict": false
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist", "prisma.config.ts"]
}